
    <%- include('partials/header')%>
    <div class="categories-container">
        <%categories.forEach((category) => {%>
            <div class="category-card">
                <img src="<%=category.image_url%>" alt="Pic of <%=category.name%>" >
                <p class="title"><%=category.name%></p>
                <p class="category-description"><%=category.description%></p>
                <div class="card-actions">
                    <a class="btn btn-view" href="/categoryDetails/<%=category.id%>">View all</a>
                    <a class="btn btn-update" href="/<%=category.id%>/updateCategory">Update</a>
                    
                </div>
                <form action="/<%=category.id%>/deleteCategory" method="post"
                        onsubmit="return confirm('Are you sure you want to Delete?')">
                    <button class=" btn-delete" type="submit">🚮</button>
                </form>

            </div>
        <%})%>
    </div>
    <%- include('partials/footer')%>
