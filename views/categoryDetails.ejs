<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
   <%- include('partials/header')%>
    <div class="items-container">
        <%items.forEach((item) => {%>
            <h1></h1>
            <div class="item-card">
                <p><%=item.name%></p>
                <p><%=item.description%></p>
                <p><%=item.price%></p>
                <p><%=item.quantity%></p>
                <p><a href="/itemDetails/<%=item.id%>">View Item</a></p>
                <img src="<%=item.image_url%>" alt="Picture of <%=item.name%>">
            </div>
        <%})%>
    </div>
</body>
</html>