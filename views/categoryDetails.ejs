
   <%- include('partials/header')%>
   <a href="/categoryDetails/<%= categoryId%>/newItem">Add New Item</a>
    <div class="items-container">
        <%items.forEach((item) => {%>
            <h1></h1>
            <div class="item-card">
                <p><%=item.name%></p>
                <p><%=item.description%></p>
                <p><%=item.price%></p>
                <p><%=item.quantity%></p>
                <p><a href="/itemDetails/<%=item.id%>">View Item</a></p>
                
                <img src="<%=item.image_url%>" alt="Picture of <%=item.name%>">
            </div>
        <%})%>
    </div>
    <%- include('partials/footer')%>
