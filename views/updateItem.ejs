    <%- include('partials/header')%>
    <%- include('partials/itemErrors')%>

    <h1>Update <%=item.name%></h1>

    <form class="form" method="POST" action="/<%=item.id%>/updateItem">

         <input type="hidden" name="category_id" value="<%= item.category_id %>">
         
        <label for="name">Name</label>
        <input id="name" name="name" value="<%=item.name%>" type="text" required>

        <label for="description">Description</label>
        <input id="description" name="description" type="text" value="<%=item.description%>" required>

        <label for="price">Price</label>
        <input id="price" min="0" name="price" type="number" step="0.01" value="<%=item.price%>" required>

        <label for="quantity">Quantity</label>
        <input id="quantity" min="0" name="quantity" type="number" value="<%=item.quantity%>" required>

        <label for="image_url">Image url</label>
        <input id="image_url" name="image_url" type="text" value="<%=item.image_url%>" placeholder="Can be left blank">

        <button type="submit">Update</button>
    </form>
    <%- include('partials/footer')%>
    
